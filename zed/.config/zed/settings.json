// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "hard_tabs": false,
  "base_keymap": "Emacs",
  "cursor_shape": "bar",
  "cursor_blink": false,
  "inline_code_actions": false,
  "close_on_file_delete": true,
  "focus_follows_mouse": {
    "enabled": false,
  },
  "debugger": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "toolbar": {
    "quick_actions": false,
    "code_actions": false,
    "breadcrumbs": false,
  },
  "inlay_hints": {
    "enabled": false,
  },
  "indent_guides": {},
  "semantic_tokens": "combined",
  "restore_on_startup": "last_session",
  "code_lens": "on",
  "cli_default_open_behavior": "new_window",
  "show_edit_predictions": false,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed",
    "codestral": {
      "model": "codestral-latest",
    },
  },
  "centered_layout": {
    "right_padding": 0.05,
    "left_padding": 0.2,
  },
  "diagnostics": {
    "include_warnings": true,
    "button": true,
    "inline": {
      "enabled": true,
    },
  },
  "git": {
    "inline_blame": {},
  },
  "audio": {
    "experimental.input_audio_device": "coreaudio:BuiltInMicrophoneDevice",
    "experimental.output_audio_device": "coreaudio:BuiltInSpeakerDevice",
    "experimental.auto_microphone_volume": true,
    "experimental.rodio_audio": true,
  },
  "calls": {
    "mute_on_join": true,
  },
  "status_bar": {
    "show_active_file": true,
    "active_language_button": true,
    "active_encoding_button": "disabled",
    "cursor_position_button": true,
  },
  "git_panel": {
    "button": false,
    "scrollbar": {
      "show": "never",
    },
    "tree_view": true,
    "collapse_untracked_diff": false,
    "sort_by_path": false,
    "status_style": "icon",
    "dock": "left",
  },
  "agent_servers": {
    "pi-acp": {
      "default_config_options": {
        "thought_level": "xhigh",
      },
      "type": "registry",
    },
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "terminal": {
    "option_as_meta": true,
    "button": false,
    "show_count_badge": false,
    "font_family": "JetBrainsMono Nerd Font",
  },
  "ssh_connections": [
    {
      "host": "prestige",
      "username": "thomas",
      "args": [],
      "projects": [
        {
          "paths": ["/home/thomas/.config/./"],
        },
        {
          "paths": ["/home/thomas/Developer/fff-gpui"],
        },
      ],
    },
    {
      "host": "windows",
      "username": "thomas",
      "args": [],
      "projects": [
        {
          "paths": ["C:\\Users\\thomas/Developer/zed"],
        },
      ],
    },
  ],
  "project_panel": {
    "starts_open": false,
    "show_diagnostics": "all",
    "button": false,
    "hide_hidden": false,
    "hide_root": false,
    "indent_guides": {
      "show": "always",
    },
    "bold_folder_labels": false,
    "folder_icons": true,
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
    "default_width": 240.0,
    "dock": "right",
    "scrollbar": {
      "horizontal_scroll": false,
      "show": "never",
    },
  },
  "window_decorations": "client",
  "bottom_dock_layout": "right_aligned",
  "soft_wrap": "editor_width",
  "minimap": {
    "show": "never",
  },
  "scrollbar": {
    "show": "never",
  },
  "autosave": "off",
  "active_pane_modifiers": {
    "border_size": 0.0,
  },
  "use_system_window_tabs": true,
  "search": {
    "center_on_match": true,
    "button": false,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_branch_status_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_sign_in": true,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_menus": true,
  },
  "tabs": {
    "show_diagnostics": "all",
    "show_close_button": "hover",
    "git_status": true,
    "file_icons": true,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "agent": {
    "button": true,
    "default_profile": "write",
    "dock": "left",
    "show_turn_stats": true,
    "use_modifier_to_send": false,
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "model_parameters": [],
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "ui_font_size": 16,
  "ui_font_family": "Alef",
  "buffer_font_size": 15,
  "theme": "Gruber Darker",
  "languages": {
    "JSON": {
      "language_servers": ["!biome", "..."],
    },
    "JSONC": {
      "language_servers": ["!biome", "..."],
    },
  },
  "language_models": {
    "openai_compatible": {
      "Foundation Models": {
        "api_url": "http://127.0.0.1:1976/v1",
        "available_models": [
          {
            "name": "system",
            "display_name": "AFM 3 Core (7b)",
            "max_tokens": 2048,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false,
            },
          },
        ],
      },
    },
  },
}
