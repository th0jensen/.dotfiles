// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed",
    "codestral": {
      "model": "codestral-latest",
    },
  },
  "centered_layout": {
    "right_padding": 0.1,
    "left_padding": 0.1,
  },
  "diagnostics": {
    "button": true,
    "inline": {
      "enabled": true,
    },
  },
  "git": {
    "inline_blame": {},
  },
  "audio": {
    "experimental.input_audio_device": "coreaudio:BuiltInMicrophoneDevice",
    "experimental.output_audio_device": "coreaudio:BuiltInSpeakerDevice",
    "experimental.auto_microphone_volume": true,
    "experimental.rodio_audio": true,
  },
  "calls": {
    "mute_on_join": true,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
    "cursor_position_button": true,
  },
  "notification_panel": {
    "button": false,
  },
  "git_panel": {
    "scrollbar": {
      "show": "never",
    },
    "tree_view": true,
    "collapse_untracked_diff": false,
    "sort_by_path": false,
    "status_style": "icon",
    "dock": "left",
  },
  "agent_servers": {
    "junie": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "mistral-vibe": {
      "default_config_options": {
        "mode": "auto-approve",
      },
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
      "favorite_config_option_values": {
        "reasoning_effort": ["high"],
      },
    },
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "terminal": {
    "show_count_badge": true,
    "font_family": "JetBrainsMono Nerd Font",
  },
  "ssh_connections": [
    {
      "host": "prestige",
      "username": "thomas",
      "args": [],
      "projects": [
        {
          "paths": ["/home/thomas/.config/./"],
        },
      ],
    },
    {
      "host": "windows",
      "username": "thomas",
      "args": [],
      "projects": [
        {
          "paths": ["C:\\Users\\thomas/Developer/zed"],
        },
      ],
    },
  ],
  "project_panel": {
    "show_diagnostics": "all",
    "button": true,
    "hide_hidden": false,
    "hide_root": false,
    "indent_guides": {
      "show": "always",
    },
    "bold_folder_labels": false,
    "indent_size": 20.0,
    "folder_icons": false,
    "entry_spacing": "standard",
    "hide_gitignore": false,
    "default_width": 240.0,
    "dock": "right",
    "scrollbar": {
      "show": "never",
    },
  },
  "window_decorations": "client",
  "bottom_dock_layout": "right_aligned",
  "soft_wrap": "editor_width",
  "minimap": {
    "show": "never",
  },
  "scrollbar": {
    "show": "never",
  },
  "autosave": "on_focus_change",
  "active_pane_modifiers": {
    "border_size": 0.0,
  },
  "use_system_window_tabs": true,
  "search": {
    "button": false,
  },
  "title_bar": {
    "show_branch_name": true,
    "show_branch_icon": true,
    "show_project_items": true,
    "show_sign_in": true,
    "show_user_menu": true,
    "show_user_picture": true,
    "show_menus": true,
  },
  "tabs": {
    "show_diagnostics": "all",
    "show_close_button": "hover",
    "git_status": true,
    "file_icons": true,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": false,
  },
  "agent": {
    "default_profile": "write",
    "dock": "left",
    "show_turn_stats": true,
    "use_modifier_to_send": false,
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "provider": "mistral",
      "model": "codestral-latest",
    },
    "model_parameters": [],
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "Gruber Darker",
}
